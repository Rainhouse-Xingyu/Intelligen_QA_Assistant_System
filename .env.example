# Copy this file to .env before docker compose up.

TZ=Asia/Shanghai

# Public ports on the host.
FRONTEND_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MILVUS_COLLECTION_NAME=knowledge_question_vector
MODEL_SERVICE_PORT=18080

# MySQL
MYSQL_DATABASE=llm_qa_sy
MYSQL_ROOT_PASSWORD=change-me-root-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# Local model files on the host.
# The directory should contain Qwen3-0.6B, Qwen2.5-1.5B-Instruct,
# bge-base-zh-v1.5, bge-reranker-large, and chinese-macbert-base.
AIGE_MODEL_BASE_HOST=/opt/aige-models
AIGE_MODEL_DEVICE=cpu

# Optional third-party service credentials.
COZE_API_TOKEN=
VOLCENGINE_SPEECH_APP_ID=
VOLCENGINE_SPEECH_API_KEY=
VOLCENGINE_SPEECH_ACCESS_TOKEN=
VOLCENGINE_SPEECH_SECRET_KEY=
VOLCENGINE_ASR_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
VOLCENGINE_ASR_QUERY_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
VOLCENGINE_ASR_RESOURCE_ID=volc.bigasr.auc_turbo
VOLCENGINE_ASR_POLL_INTERVAL_MS=1500
VOLCENGINE_ASR_POLL_TIMEOUT_MS=30000
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_SPEAKER=zh_female_vv_uranus_bigtts
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
